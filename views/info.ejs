<%
function speakerSVG() {
  return '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>';
}
%>
<%- include('partials/header', { pageTitle: '旅遊資訊', navTitle: '旅遊資訊', navBack: null }) %>

<style>
.pass-tbl{width:100%;border-collapse:collapse;font-size:.73rem}
.pass-tbl th,.pass-tbl td{text-align:left;padding:6px 7px;border-bottom:1px solid var(--border-l);vertical-align:middle}
.pass-tbl thead tr{background:var(--bg2)}
.pass-tbl th{color:var(--t3);font-weight:600;white-space:nowrap}
.pt-day,.pt-dc{width:26px;min-width:26px;white-space:nowrap;font-weight:700;color:var(--t1);padding-left:10px}
.pt-route,.pt-rc{color:var(--t1)}
.pt-rc-mode{font-size:.65rem;color:var(--t3);margin-top:2px}
.pt-tick,.pt-tc{width:24px;min-width:24px;text-align:center;padding:6px 3px;font-weight:700}
.pt-cost,.pt-cc{min-width:54px;white-space:nowrap;color:var(--t2);text-align:right;padding-right:10px}
.pt-H{color:#F4845F}.pt-I{color:#5E97F6}.pt-K{color:#66BB6A}.pt-C{color:#B2BEC3}
.pt-sep td{border-top:2px solid var(--border)}
.pass-legend{display:flex;flex-wrap:wrap;gap:6px 14px;padding:10px 12px 8px}
.pass-legend-item{display:flex;align-items:center;gap:5px;font-size:.72rem;color:var(--t2)}
.pass-legend-dot{display:inline-block;width:10px;height:10px;border-radius:3px;flex-shrink:0}
.app-chips{display:flex;flex-wrap:wrap;gap:8px;padding:8px 0 6px}
.app-chip{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:20px;background:var(--fill);border:1px solid var(--border-l);font-size:13px;font-weight:500;color:var(--t1);text-decoration:none;transition:background .12s}
.app-chip:active{background:var(--border-l)}
.app-chip-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.acc-sub{font-size:.72rem;color:var(--t3);line-height:1.6;padding-top:2px}
</style>

<!-- 分頁切換 -->
<div class="seg-ctrl">
  <button class="seg-btn active" id="seg-trip"       onclick="switchSeg('trip')">行程</button>
  <button class="seg-btn"        id="seg-taxi"       onclick="switchSeg('taxi')">交通</button>
  <button class="seg-btn"        id="seg-restaurant" onclick="switchSeg('restaurant')">餐廳</button>
  <button class="seg-btn"        id="seg-check"      onclick="switchSeg('check')">清單</button>
</div>

<!-- ══════════════════════════════════════════════════
     面板 A：行程資訊（DB 動態）
═══════════════════════════════════════════════════ -->
<div id="panel-trip">
<%
const catIcon    = { '班機':'✈️', '住宿':'🏨', '緊急':'🆘', '實用':'💡', '交通':'🚇', '上網':'📶', '租車':'🚗' };
const catOpenDef = {};
%>
<div class="section">
  <div class="section-title">📋 &nbsp;行程資訊</div>
  <div class="card-list">
    <% Object.entries(info).forEach(([cat, items]) => {
       const isOpen = !!catOpenDef[cat];
    %>
    <div class="accordion">
      <div class="acc-hd <%= isOpen ? 'open' : '' %>" onclick="toggleAcc(this)">
        <span class="acc-hd-icon"><%= catIcon[cat] || '📌' %></span>
        <span class="acc-title"><%= cat %></span>
        <svg class="acc-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
      <div class="acc-body <%= isOpen ? 'open' : '' %>">
        <% items.forEach(item => { %>
        <div class="info-row" id="info-<%= item.id %>">
          <div class="info-row-head">
            <div class="info-key"><%= item.key %></div>
            <button class="info-edit-btn" onclick="editInfo(<%= item.id %>, '<%= item.key.replace(/'/g,"\\'") %>', `<%= (item.value||'').replace(/`/g,'\\`') %>`)">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
              </svg>
            </button>
          </div>
          <div class="info-val<%= item.value ? '' : ' empty' %>" id="info-val-<%= item.id %>"><%= item.value || '點擊填寫' %></div>
        </div>
        <% }) %>
      </div>
    </div>
    <% }) %>
  </div>
</div>
</div>

<!-- ══════════════════════════════════════════════════
     面板 B：交通（計程車）
═══════════════════════════════════════════════════ -->
<div id="panel-taxi" style="display:none">

  <!-- 票券使用指南 -->
  <div class="section">
    <div style="background:var(--card);border-radius:var(--r-lg);box-shadow:var(--shadow-s)">
      <div>
        <div class="pass-legend">
          <div class="pass-legend-item"><span class="pass-legend-dot" style="background:#F4845F"></span>HARUKA（外國人優惠票）</div>
          <div class="pass-legend-item"><span class="pass-legend-dot" style="background:#5E97F6"></span>ICOCA（西瓜卡）</div>
          <div class="pass-legend-item"><span class="pass-legend-dot" style="background:#66BB6A"></span>KANSAI PASS（關西鐵路周遊券）</div>
          <div class="pass-legend-item"><span class="pass-legend-dot" style="background:#B2BEC3"></span>現金</div>
        </div>
        <div style="overflow-x:auto;-webkit-overflow-scrolling:touch">
          <table class="pass-tbl">
            <thead>
              <tr>
                <th class="pt-day">日</th>
                <th class="pt-route">路線／方式</th>
                <th class="pt-tick" style="color:#F4845F">H</th>
                <th class="pt-tick" style="color:#5E97F6">I</th>
                <th class="pt-tick" style="color:#66BB6A">K</th>
                <th class="pt-tick" style="color:#B2BEC3">C</th>
                <th class="pt-cost">費用/人</th>
              </tr>
            </thead>
            <tbody>
<%
const PASS_ROWS = [
  { day:'D1', sep:true,  route:'KIX → 京都駅',         mode:'JR HARUKA 特急',    H:1,I:0,K:0,C:0, cost:'¥2,200' },
  { day:'',   sep:false, route:'京都駅 → Minn 飯店',    mode:'地下鐵・步行',       H:0,I:1,K:0,C:0, cost:'¥260'   },
  { day:'D2', sep:true,  route:'三条京阪 → 丹波橋',     mode:'京阪本線',           H:0,I:0,K:1,C:0, cost:'¥280'   },
  { day:'',   sep:false, route:'丹波橋 → 近鐵奈良',     mode:'近鐵急行',           H:0,I:0,K:1,C:0, cost:'¥780'   },
  { day:'',   sep:false, route:'奈良市內巴士',           mode:'市內バス',           H:0,I:1,K:0,C:0, cost:'~¥250'  },
  { day:'',   sep:false, route:'近鐵奈良 → 三条京阪',   mode:'近鐵＋京阪',         H:0,I:0,K:1,C:0, cost:'¥1,060' },
  { day:'D3', sep:true,  route:'三条 → 出町柳',         mode:'京阪本線',           H:0,I:0,K:1,C:0, cost:'¥220'   },
  { day:'',   sep:false, route:'出町柳 → 貴船口',        mode:'叡山電鐵',           H:0,I:0,K:1,C:0, cost:'¥430'   },
  { day:'',   sep:false, route:'貴船口 → 三条',          mode:'叡電＋京阪',         H:0,I:0,K:1,C:0, cost:'¥650'   },
  { day:'D4', sep:true,  route:'飯店 → 伏見稻荷',       mode:'計程車',             H:0,I:0,K:0,C:1, cost:'~¥400※' },
  { day:'',   sep:false, route:'伏見稻荷 → 清水坂',     mode:'計程車',             H:0,I:0,K:0,C:1, cost:'~¥350※' },
  { day:'',   sep:false, route:'清水 → 八坂 → 飯店',   mode:'步行',               H:0,I:0,K:0,C:0, cost:'免費'   },
  { day:'',   sep:false, route:'飯店 → 京都駅',         mode:'地下鐵',             H:0,I:1,K:0,C:0, cost:'¥260'   },
  { day:'',   sep:false, route:'京都 → 大阪梅田',       mode:'JR 新快速',          H:0,I:1,K:0,C:0, cost:'¥570'   },
  { day:'',   sep:false, route:'梅田 → 難波',           mode:'大阪メトロ',         H:0,I:1,K:0,C:0, cost:'¥180'   },
  { day:'D5', sep:true,  route:'難波 → 三宮',           mode:'阪神電車',           H:0,I:1,K:0,C:0, cost:'¥430'   },
  { day:'',   sep:false, route:'三宮 → 摩耶纜車站',     mode:'市バス',             H:0,I:1,K:0,C:0, cost:'¥230'   },
  { day:'',   sep:false, route:'摩耶山 纜車往返',         mode:'纜車＋ロープウェイ', H:0,I:0,K:0,C:1, cost:'¥1,560' },
  { day:'',   sep:false, route:'摩耶 → 三宮',           mode:'市バス',             H:0,I:1,K:0,C:0, cost:'¥230'   },
  { day:'',   sep:false, route:'三宮 → 難波',           mode:'阪神電車',           H:0,I:1,K:0,C:0, cost:'¥430'   },
  { day:'D6', sep:true,  route:'難波 → りんくうタウン', mode:'南海本線',           H:0,I:0,K:1,C:0, cost:'¥920'   },
  { day:'',   sep:false, route:'りんくう → KIX',         mode:'南海空港線',         H:0,I:0,K:1,C:0, cost:'¥120'   },
];
PASS_ROWS.forEach(r => { %>
              <tr class="<%= r.sep ? 'pt-sep' : '' %>">
                <td class="pt-dc"><%= r.day %></td>
                <td class="pt-rc">
                  <%= r.route %>
                  <div class="pt-rc-mode"><%= r.mode %></div>
                </td>
                <td class="pt-tc <%= r.H ? 'pt-H' : '' %>"><%= r.H ? '✓' : '' %></td>
                <td class="pt-tc <%= r.I ? 'pt-I' : '' %>"><%= r.I ? '✓' : '' %></td>
                <td class="pt-tc <%= r.K ? 'pt-K' : '' %>"><%= r.K ? '✓' : '' %></td>
                <td class="pt-tc <%= r.C ? 'pt-C' : '' %>"><%= r.C ? '✓' : '' %></td>
                <td class="pt-cc"><%= r.cost %></td>
              </tr>
<% }); %>
            </tbody>
          </table>
        </div>
        <div style="padding:10px 14px 6px;font-size:.7rem;color:var(--t3);line-height:1.7">
          ※ 計程車費用為 6 人包車均攤估算 &nbsp;·&nbsp; K = KANSAI RAILWAY PASS LITE 3日券 ¥6,500/人（建議啟用日：D2・D3・D6）
        </div>
      </div>
    </div>
  </div>

  <!-- Accordion 參考資訊 -->
  <div class="section">
    <div class="card-list">

      <!-- 叫車 App -->
      <div class="accordion">
        <div class="acc-hd" onclick="toggleAcc(this)">
          <span class="acc-hd-icon">🚕</span>
          <span class="acc-title">叫車 App</span>
          <svg class="acc-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
        <div class="acc-body">
          <div class="app-chips">
            <a href="https://go.goinc.jp/" target="_blank" rel="noopener" class="app-chip">
              <span class="app-chip-dot" style="background:#E8FF00;border:1px solid #ccc"></span>GO タクシー
            </a>
            <a href="https://didimobility.co.jp/" target="_blank" rel="noopener" class="app-chip">
              <span class="app-chip-dot" style="background:#FF6700"></span>DiDi 打車
            </a>
            <a href="https://www.uber.com/jp/ja/ride/" target="_blank" rel="noopener" class="app-chip">
              <span class="app-chip-dot" style="background:#000"></span>Uber
            </a>
          </div>
          <div class="acc-sub">GO 全日本最大・免預付款最推薦　DiDi 大阪京都均可　Uber 日本為正規計程車</div>
        </div>
      </div>

      <!-- 計費方式 -->
      <div class="accordion">
        <div class="acc-hd" onclick="toggleAcc(this)">
          <span class="acc-hd-icon">💴</span>
          <span class="acc-title">計費方式</span>
          <svg class="acc-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
        <div class="acc-body">
          <div class="taxi-fare-row"><span>大阪 初乘</span><span>¥680 / 約 1km</span></div>
          <div class="taxi-fare-row"><span>京都 初乘</span><span>¥670 / 約 1km</span></div>
          <div class="taxi-fare-row"><span>追加跳表</span><span>約 ¥80 / 每 233m</span></div>
          <div class="taxi-fare-row taxi-warn-row"><span>深夜加成 ⚠</span><span class="taxi-warn">22:00–05:00  +20%</span></div>
        </div>
      </div>

      <!-- 路線估算 -->
      <div class="accordion">
        <div class="acc-hd" onclick="toggleAcc(this)">
          <span class="acc-hd-icon">📍</span>
          <span class="acc-title">路線車資估算</span>
          <svg class="acc-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
        <div class="acc-body">
          <div class="taxi-fare-row"><span>難波 → 大阪城</span><span>約 ¥1,200</span></div>
          <div class="taxi-fare-row"><span>難波 → 心齋橋</span><span>約 ¥700</span></div>
          <div class="taxi-fare-row"><span>難波 → USJ</span><span>約 ¥2,500</span></div>
          <div class="taxi-fare-row"><span>京都駅 → 清水寺</span><span>約 ¥1,000</span></div>
          <div class="taxi-fare-row"><span>京都駅 → 金閣寺</span><span>約 ¥1,500</span></div>
          <div class="taxi-fare-row"><span>京都駅 → 嵐山</span><span>約 ¥2,800</span></div>
          <div class="taxi-fare-row taxi-warn-row"><span>KIX → 難波 ⚠ 建議搭電車</span><span class="taxi-warn">¥8,000–10,000</span></div>
        </div>
      </div>

      <!-- 乘車須知 -->
      <div class="accordion">
        <div class="acc-hd" onclick="toggleAcc(this)">
          <span class="acc-hd-icon">🚪</span>
          <span class="acc-title">乘車須知</span>
          <svg class="acc-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
        <div class="acc-body">
          <div class="taxi-tip">🚪 後座<strong>左側車門自動開關</strong>，切勿用手拉</div>
          <div class="taxi-tip">💴 不需小費，現金 / IC 卡 / 信用卡均可（各車略不同）</div>
          <div class="taxi-tip">🙋 路邊招手或在車站「タクシー乗り場」排隊</div>
          <div class="taxi-tip">📱 直接把 Google Maps 目的地畫面給司機看即可</div>
          <div class="taxi-tip">🧾 可索取收據（領収書）用於報帳記帳</div>
        </div>
      </div>

      <!-- 常用日語 + TTS -->
      <div class="accordion">
        <div class="acc-hd" onclick="toggleAcc(this)">
          <span class="acc-hd-icon">💬</span>
          <span class="acc-title">常用日語 <small style="font-weight:400;color:var(--t3);font-size:11px">點 🔊 聽發音</small></span>
          <svg class="acc-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
        <div class="acc-body">
          <div class="taxi-phrase">
            <span class="taxi-jp">ここまでお願いします</span>
            <span class="taxi-tw">請帶我到這裡（搭配手機畫面）</span>
            <button class="speak-btn" onclick="speakJP('ここまでお願いします',this)"><%- speakerSVG() %></button>
          </div>
          <div class="taxi-phrase">
            <span class="taxi-jp">ここで降ろしてください</span>
            <span class="taxi-tw">請在這裡讓我下車</span>
            <button class="speak-btn" onclick="speakJP('ここで降ろしてください',this)"><%- speakerSVG() %></button>
          </div>
          <div class="taxi-phrase">
            <span class="taxi-jp">領収書をください</span>
            <span class="taxi-tw">請給我收據</span>
            <button class="speak-btn" onclick="speakJP('領収書をください',this)"><%- speakerSVG() %></button>
          </div>
          <div class="taxi-phrase">
            <span class="taxi-jp">急いでいます</span>
            <span class="taxi-tw">我趕時間</span>
            <button class="speak-btn" onclick="speakJP('急いでいます',this)"><%- speakerSVG() %></button>
          </div>
          <div class="taxi-phrase">
            <span class="taxi-jp">クレジットカードは使えますか？</span>
            <span class="taxi-tw">可以刷信用卡嗎？</span>
            <button class="speak-btn" onclick="speakJP('クレジットカードは使えますか？',this)"><%- speakerSVG() %></button>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════
     面板 C：餐廳禮儀
═══════════════════════════════════════════════════ -->
<div id="panel-restaurant" style="display:none">

  <!-- Accordion 指南 -->
  <div class="section">
    <div class="card-list">

      <!-- 美食 App -->
      <div class="accordion">
        <div class="acc-hd" onclick="toggleAcc(this)">
          <span class="acc-hd-icon">📲</span>
          <span class="acc-title">美食 App</span>
          <svg class="acc-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
        <div class="acc-body">
          <div class="app-chips">
            <a href="https://tabelog.com/" target="_blank" rel="noopener" class="app-chip">
              <span class="app-chip-dot" style="background:#C8353A"></span>食べログ
            </a>
            <a href="https://www.gnavi.co.jp/" target="_blank" rel="noopener" class="app-chip">
              <span class="app-chip-dot" style="background:#E84A2F"></span>ぐるなび
            </a>
            <a href="https://www.hotpepper.jp/gourmet/" target="_blank" rel="noopener" class="app-chip">
              <span class="app-chip-dot" style="background:#FF0033"></span>Hot Pepper
            </a>
          </div>
          <div class="acc-sub">食べログ 最大評分平台　ぐるなび 線上訂位（含英文）　Hot Pepper 訂位附折扣券</div>
        </div>
      </div>

      <!-- 用餐禮儀 -->
      <div class="accordion">
        <div class="acc-hd" onclick="toggleAcc(this)">
          <span class="acc-hd-icon">🙏</span>
          <span class="acc-title">用餐禮儀</span>
          <svg class="acc-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
        <div class="acc-body">
          <div class="taxi-tip">🙏 <strong>いただきます</strong> 開動前說，<strong>ごちそうさまでした</strong> 結束後說</div>
          <div class="taxi-tip">🍜 吃拉麵、蕎麥麵發出聲音是正常且有禮的</div>
          <div class="taxi-tip">🧻 入座有冷/熱毛巾（おしぼり），擦手用，不擦臉</div>
          <div class="taxi-tip">🔔 需要服務喊「すみません」或按桌邊呼叫鈕</div>
          <div class="taxi-tip">💴 不需小費，零錢不要留在桌上</div>
          <div class="taxi-tip">🚭 許多餐廳仍有吸煙區，可要求禁煙座（禁煙席）</div>
          <div class="taxi-tip">🏮 門口食物模型（食品サンプル）可直接指著點餐</div>
          <div class="taxi-tip">🎫 部分店家用自動點餐機（券売機）先買票再入座</div>
        </div>
      </div>

      <!-- 實用小知識 -->
      <div class="accordion">
        <div class="acc-hd" onclick="toggleAcc(this)">
          <span class="acc-hd-icon">💡</span>
          <span class="acc-title">實用小知識</span>
          <svg class="acc-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
        <div class="acc-body">
          <div class="taxi-fare-row"><span>午間套餐</span><span>比晚餐便宜 30–50%</span></div>
          <div class="taxi-fare-row"><span>人氣店訂位</span><span>建議提前 1–2 週</span></div>
          <div class="taxi-fare-row"><span>付款時機</span><span>用餐後結帳（先付制除外）</span></div>
          <div class="taxi-fare-row"><span>分開結帳</span><span>說「別々に」多數餐廳配合</span></div>
          <div class="taxi-fare-row"><span>消費稅</span><span>10%（外帶 8%），含在標示價內</span></div>
        </div>
      </div>

      <!-- 點餐日語 + TTS -->
      <div class="accordion">
        <div class="acc-hd" onclick="toggleAcc(this)">
          <span class="acc-hd-icon">💬</span>
          <span class="acc-title">點餐日語 <small style="font-weight:400;color:var(--t3);font-size:11px">點 🔊 聽發音</small></span>
          <svg class="acc-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
        <div class="acc-body">
          <div class="taxi-phrase">
            <span class="taxi-jp">すみません</span>
            <span class="taxi-tw">不好意思（呼叫服務員）</span>
            <button class="speak-btn" onclick="speakJP('すみません',this)"><%- speakerSVG() %></button>
          </div>
          <div class="taxi-phrase">
            <span class="taxi-jp">これをください</span>
            <span class="taxi-tw">我要這個（指著菜單說）</span>
            <button class="speak-btn" onclick="speakJP('これをください',this)"><%- speakerSVG() %></button>
          </div>
          <div class="taxi-phrase">
            <span class="taxi-jp">英語のメニューはありますか？</span>
            <span class="taxi-tw">有英文菜單嗎？</span>
            <button class="speak-btn" onclick="speakJP('英語のメニューはありますか？',this)"><%- speakerSVG() %></button>
          </div>
          <div class="taxi-phrase">
            <span class="taxi-jp">おすすめは何ですか？</span>
            <span class="taxi-tw">你們的招牌是什麼？</span>
            <button class="speak-btn" onclick="speakJP('おすすめは何ですか？',this)"><%- speakerSVG() %></button>
          </div>
          <div class="taxi-phrase">
            <span class="taxi-jp">お水をください</span>
            <span class="taxi-tw">請給我水（多數餐廳免費）</span>
            <button class="speak-btn" onclick="speakJP('お水をください',this)"><%- speakerSVG() %></button>
          </div>
          <div class="taxi-phrase">
            <span class="taxi-jp">お会計をお願いします</span>
            <span class="taxi-tw">麻煩結帳</span>
            <button class="speak-btn" onclick="speakJP('お会計をお願いします',this)"><%- speakerSVG() %></button>
          </div>
          <div class="taxi-phrase">
            <span class="taxi-jp">別々でお願いします</span>
            <span class="taxi-tw">請分開結帳</span>
            <button class="speak-btn" onclick="speakJP('別々でお願いします',this)"><%- speakerSVG() %></button>
          </div>
          <div class="taxi-phrase">
            <span class="taxi-jp">ごちそうさまでした</span>
            <span class="taxi-tw">謝謝招待，很好吃</span>
            <button class="speak-btn" onclick="speakJP('ごちそうさまでした',this)"><%- speakerSVG() %></button>
          </div>
        </div>
      </div>

      <!-- 過敏用語 + TTS -->
      <div class="accordion">
        <div class="acc-hd" onclick="toggleAcc(this)">
          <span class="acc-hd-icon">⚕️</span>
          <span class="acc-title">過敏 / 飲食限制 <small style="font-weight:400;color:var(--t3);font-size:11px">點 🔊 聽發音</small></span>
          <svg class="acc-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
        <div class="acc-body">
          <div class="taxi-phrase">
            <span class="taxi-jp">アレルギーがあります</span>
            <span class="taxi-tw">我有過敏</span>
            <button class="speak-btn" onclick="speakJP('アレルギーがあります',this)"><%- speakerSVG() %></button>
          </div>
          <div class="taxi-phrase">
            <span class="taxi-jp">豚肉は食べられません</span>
            <span class="taxi-tw">我不吃豬肉</span>
            <button class="speak-btn" onclick="speakJP('豚肉は食べられません',this)"><%- speakerSVG() %></button>
          </div>
          <div class="taxi-phrase">
            <span class="taxi-jp">牛肉は食べられません</span>
            <span class="taxi-tw">我不吃牛肉</span>
            <button class="speak-btn" onclick="speakJP('牛肉は食べられません',this)"><%- speakerSVG() %></button>
          </div>
          <div class="taxi-phrase">
            <span class="taxi-jp">魚介類は食べられません</span>
            <span class="taxi-tw">我不吃海鮮</span>
            <button class="speak-btn" onclick="speakJP('魚介類は食べられません',this)"><%- speakerSVG() %></button>
          </div>
          <div class="taxi-phrase">
            <span class="taxi-jp">これに〇〇は入っていますか？</span>
            <span class="taxi-tw">這裡面有〇〇嗎？</span>
            <button class="speak-btn" onclick="speakJP('これに何か入っていますか？',this)"><%- speakerSVG() %></button>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════
     面板 D：打包清單
═══════════════════════════════════════════════════ -->
<div id="panel-check" style="display:none">
<div class="hero" style="padding:14px 20px 12px;border-bottom:1px solid var(--border-l)">
  <div style="display:flex;align-items:center;gap:12px">
    <div style="flex:1;height:6px;background:var(--border-l);border-radius:3px;overflow:hidden">
      <div id="progressBar" style="height:100%;background:var(--t1);border-radius:3px;transition:width .4s ease;width:<%= total > 0 ? Math.round(done/total*100) : 0 %>%"></div>
    </div>
    <div style="font-size:var(--fs-meta);color:var(--t3);white-space:nowrap;font-weight:500">
      <span id="progressText"><%= done %></span> / <%= total %>
    </div>
  </div>
</div>
<% Object.entries(checks).forEach(([cat, items]) => { %>
<div class="section">
  <div class="section-title">🧳 &nbsp;<%= cat %></div>
  <div class="card-list">
    <% items.forEach(item => { %>
    <label class="check-row" id="check-<%= item.id %>">
      <input type="checkbox" class="check-input" <%= item.checked ? 'checked' : '' %>
        onchange="toggleCheck(<%= item.id %>, this.checked)" style="display:none">
      <div class="check-box <%= item.checked ? 'checked' : '' %>" id="checkBox-<%= item.id %>">
        <% if (item.checked) { %>
        <svg width="11" height="9" viewBox="0 0 11 9" fill="none">
          <path d="M1 4L4 7L10 1" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <% } %>
      </div>
      <span class="check-label <%= item.checked ? 'checked' : '' %>" id="checkLabel-<%= item.id %>"><%= item.item %></span>
      <button class="check-del" onclick="event.preventDefault();deleteCheck(<%= item.id %>)">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </label>
    <% }) %>
  </div>
</div>
<% }) %>
<div style="padding:8px 16px 0">
  <button class="add-btn" onclick="openAddCheck()">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
    新增項目
  </button>
</div>
</div>

<!-- ══ Modals ════════════════════════════════════════ -->
<div id="infoOverlay" class="overlay" onclick="if(event.target===this)closeInfoModal()">
  <div class="sheet">
    <div class="sheet-handle"></div>
    <div class="sheet-title" id="infoModalTitle">編輯資訊</div>
    <input type="hidden" id="infoId">
    <div class="fg"><textarea id="infoValue" style="height:90px" placeholder="輸入內容..."></textarea></div>
    <div class="btn-row">
      <button class="btn btn-sec" onclick="closeInfoModal()">取消</button>
      <button class="btn btn-pri" onclick="saveInfo()">儲存</button>
    </div>
  </div>
</div>

<div id="checkOverlay" class="overlay" onclick="if(event.target===this)closeCheckModal()">
  <div class="sheet">
    <div class="sheet-handle"></div>
    <div class="sheet-title">新增清單項目</div>
    <div class="fg">
      <label>類別</label>
      <input type="text" id="checkCat" placeholder="例：3C、衣物、生活">
    </div>
    <div class="fg">
      <label>項目名稱 *</label>
      <input type="text" id="checkItem" placeholder="例：護照">
    </div>
    <div class="btn-row">
      <button class="btn btn-sec" onclick="closeCheckModal()">取消</button>
      <button class="btn btn-pri" onclick="saveCheck()">新增</button>
    </div>
  </div>
</div>

<script>
/* ── Tab switching ────────────────────────── */
const PANELS = ['trip', 'taxi', 'restaurant', 'check'];
function switchSeg(tab) {
  PANELS.forEach(p => {
    document.getElementById('panel-' + p).style.display = p === tab ? '' : 'none';
    document.getElementById('seg-' + p).classList.toggle('active', p === tab);
  });
}

/* ── Accordion ───────────────────────────── */
function toggleAcc(hd) {
  hd.classList.toggle('open');
  hd.nextElementSibling.classList.toggle('open');
}

/* ── Text-to-Speech ──────────────────────── */
function speakJP(text, btn) {
  if (!window.speechSynthesis) { showToast('此裝置不支援語音播放'); return; }
  if (btn.classList.contains('playing')) {
    speechSynthesis.cancel();
    btn.classList.remove('playing');
    return;
  }
  speechSynthesis.cancel();
  document.querySelectorAll('.speak-btn.playing').forEach(b => b.classList.remove('playing'));
  const u = new SpeechSynthesisUtterance(text);
  u.lang = 'ja-JP';
  u.rate = 0.82;
  u.onend  = () => btn.classList.remove('playing');
  u.onerror = () => btn.classList.remove('playing');
  btn.classList.add('playing');
  speechSynthesis.speak(u);
}

/* ── Checklist ───────────────────────────── */
const CHECKLIST_TOTAL = <%= total %>;
let checkDone = <%= done %>;

function updateProgress(delta) {
  checkDone += delta;
  document.getElementById('progressText').textContent = checkDone;
  const pct = CHECKLIST_TOTAL > 0 ? Math.round(checkDone / CHECKLIST_TOTAL * 100) : 0;
  document.getElementById('progressBar').style.width = pct + '%';
}

async function toggleCheck(id, checked) {
  requireAuth(async () => {
    const r = await fetch('/api/checklist/' + id, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json', 'x-edit-token': editToken },
      body: JSON.stringify({ checked })
    });
    if (r.status === 401) { editToken = null; sessionStorage.removeItem('trip_token'); return; }
    const box = document.getElementById('checkBox-' + id);
    const lbl = document.getElementById('checkLabel-' + id);
    if (checked) {
      box.classList.add('checked');
      box.innerHTML = '<svg width="11" height="9" viewBox="0 0 11 9" fill="none"><path d="M1 4L4 7L10 1" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>';
      lbl.classList.add('checked');
      updateProgress(1);
    } else {
      box.classList.remove('checked');
      box.innerHTML = '';
      lbl.classList.remove('checked');
      updateProgress(-1);
    }
  });
}

async function deleteCheck(id) {
  requireAuth(async () => {
    if (!confirm('確定刪除？')) return;
    const r = await fetch('/api/checklist/' + id, { method: 'DELETE', headers: { 'x-edit-token': editToken } });
    if (!r.ok) return showToast('刪除失敗');
    document.getElementById('check-' + id).remove();
    showToast('已刪除');
  });
}

function openAddCheck() {
  requireAuth(() => {
    document.getElementById('checkCat').value = '';
    document.getElementById('checkItem').value = '';
    document.getElementById('checkOverlay').classList.add('open');
    setTimeout(() => document.getElementById('checkItem').focus(), 350);
  });
}
function closeCheckModal() { document.getElementById('checkOverlay').classList.remove('open'); }

async function saveCheck() {
  const item = document.getElementById('checkItem').value.trim();
  if (!item) { showToast('請輸入項目名稱'); return; }
  const r = await fetch('/api/checklist', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'x-edit-token': editToken },
    body: JSON.stringify({ category: document.getElementById('checkCat').value.trim() || '其他', item })
  });
  if (!r.ok) return showToast('新增失敗');
  closeCheckModal();
  showToast('已新增');
  setTimeout(() => location.reload(), 400);
}

/* ── Trip info edit ──────────────────────── */
function editInfo(id, key, value) {
  requireAuth(() => {
    document.getElementById('infoId').value = id;
    document.getElementById('infoModalTitle').textContent = key;
    document.getElementById('infoValue').value = value;
    document.getElementById('infoOverlay').classList.add('open');
    setTimeout(() => document.getElementById('infoValue').focus(), 350);
  });
}
function closeInfoModal() { document.getElementById('infoOverlay').classList.remove('open'); }

async function saveInfo() {
  const id = document.getElementById('infoId').value;
  const value = document.getElementById('infoValue').value.trim();
  const r = await fetch('/api/info/' + id, {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json', 'x-edit-token': editToken },
    body: JSON.stringify({ value })
  });
  if (!r.ok) return showToast('儲存失敗');
  document.getElementById('info-val-' + id).textContent = value || '點擊填寫';
  closeInfoModal();
  showToast('已儲存');
}
</script>

<%- include('partials/footer', { activePage: 'info' }) %>
