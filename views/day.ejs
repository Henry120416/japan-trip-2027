<%
  const weekMap = ['日','一','二','三','四','五','六'];
  const d = new Date(day.date + 'T00:00:00');
  const wd = weekMap[d.getDay()];
  const catMap = {
    transport: { ico: '✈', lbl: '交通' },
    food:      { ico: '🍜', lbl: '餐廳' },
    attraction:{ ico: '🏛', lbl: '景點' },
    hotel:     { ico: '🏨', lbl: '住宿' },
    other:     { ico: '📌', lbl: '其他' },
  };
%>
<%- include('partials/header', {
  pageTitle: day.title,
  navTitle: day.title,
  navBack: '/'
}) %>

<div class="hero" style="padding:20px 20px 16px">
  <div class="hero-sub" style="font-size:13px">
    週<%= wd %> · <%= day.date.replace(/-/g,'/') %> · <span class="city-tag" style="vertical-align:middle"><%= day.city %></span>
  </div>
  <% if (day.notes) { %>
    <div style="font-size:14px;color:var(--t3);margin-top:8px;line-height:1.5"><%= day.notes %></div>
  <% } %>
</div>

<div class="timeline">
  <% if (activities.length === 0) { %>
    <div class="empty">
      <div class="empty-icon">🗓</div>
      <div class="empty-txt">尚無行程</div>
      <div class="empty-hint">點擊下方按鈕新增第一個行程</div>
    </div>
  <% } else { %>
    <% activities.forEach(a => { %>
      <div class="tl-item">
        <div class="tl-time"><%= a.time || '—' %></div>
        <div class="tl-track">
          <div class="tl-dot"></div>
          <div class="tl-line"></div>
        </div>
        <div class="tl-card">
          <div class="tl-card-head">
            <div class="act-title"><%= a.title %></div>
            <div class="act-actions">
              <button class="act-btn" onclick='openEditActivity(<%- JSON.stringify(a) %>)' title="編輯">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
              </button>
              <button class="act-btn del" onclick="deleteActivity(<%= a.id %>)" title="刪除">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="3 6 5 6 21 6"/>
                  <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                  <path d="M10 11v6M14 11v6"/>
                </svg>
              </button>
            </div>
          </div>
          <% if (a.location) { %>
            <div class="act-loc">
              <svg width="11" height="13" viewBox="0 0 24 28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
                <circle cx="12" cy="9" r="2.5"/>
              </svg>
              <%= a.location %>
            </div>
          <% } %>
          <% if (a.image_url) { %>
            <img src="<%= a.image_url %>" alt="<%= a.title %>" class="act-img" loading="lazy" onerror="this.style.display='none'">
          <% } %>
          <% if (a.description) { %>
            <div class="act-desc"><%= a.description %></div>
          <% } %>
          <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
            <span class="cat-pill">
              <%= catMap[a.category] ? catMap[a.category].ico : '📌' %>
              <%= catMap[a.category] ? catMap[a.category].lbl : a.category %>
            </span>
            <% if (a.map_url) { %>
              <a href="<%= a.map_url %>" target="_blank" class="act-map">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                地圖
              </a>
            <% } %>
          </div>
        </div>
      </div>
    <% }) %>
  <% } %>

  <button class="add-btn" onclick="openAddActivity(<%= day.id %>)">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
    新增行程
  </button>
</div>

<%- include('partials/footer', { activePage: 'home' }) %>
