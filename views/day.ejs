<%
  const weekMap = ['日','一','二','三','四','五','六'];
  const d = new Date(day.date + 'T00:00:00');
  const wd = weekMap[d.getDay()];
  const catMap = {
    transport: { ico: '✈', lbl: '交通' },
    food:      { ico: '🍜', lbl: '餐廳' },
    attraction:{ ico: '🏛', lbl: '景點' },
    hotel:     { ico: '🏨', lbl: '住宿' },
    other:     { ico: '📌', lbl: '其他' },
  };
  const stationMapDB = [
    { keys: ['KIX','関西空港','關西空港','Haruka','はるか','登機','Check-out'], url: 'https://www.kansai-airport.or.jp/en/map/' },
    { keys: ['JR京都','京都駅','京都站','前往京都','前往大阪'], url: 'https://eki.jr-odekake.net/premises?id=0610116' },
    { keys: ['JR大阪','大阪駅','大阪站'], url: 'https://eki.jr-odekake.net/premises?id=0610130' },
    { keys: ['難波','なんば','Rapi:t','南海'], url: 'https://www.nankai.co.jp/tc_railway/traffic/station/namba.html' },
    { keys: ['祇園四条','祇園四條'], url: 'https://www.keihan.co.jp/traffic/station/162/info.html' },
    { keys: ['伏見稲荷','伏見稻荷'], url: 'https://www.keihan.co.jp/traffic/station/151/info.html' },
    { keys: ['USJ','ユニバーサル','Universal'], url: 'https://eki.jr-odekake.net/premises?id=0612204' },
  ];
%>
<%- include('partials/header', {
  pageTitle: day.title,
  navTitle: day.title,
  navBack: '/'
}) %>

<div class="hero" style="padding:20px 20px 16px">
  <div class="hero-sub" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:6px">
    <span>週<%= wd %> · <%= day.date.replace(/-/g,'/') %> · <span class="city-tag" style="vertical-align:middle"><%= day.city %></span></span>
    <a href="/day/<%= day.date %>/map" class="map-route-link">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/>
        <line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/>
      </svg>
      路線地圖
    </a>
  </div>
  <% if (day.notes) { %>
    <div style="font-size:var(--fs-body);color:var(--t3);margin-top:8px;line-height:1.5"><%= day.notes %></div>
  <% } %>
</div>

<div class="timeline">
  <% if (activities.length === 0) { %>
    <div class="empty">
      <div class="empty-icon">🗓</div>
      <div class="empty-txt">尚無行程</div>
      <div class="empty-hint">點擊下方按鈕新增第一個行程</div>
    </div>
  <% } else { %>
    <% activities.forEach(a => { %>
      <div class="tl-item">
        <div class="tl-time">
          <%= a.time || '—' %>
          <% if (a.time) { %>
            <div class="tl-time-lbl"><%= a.category === 'transport' ? '出發' : '抵達' %></div>
          <% } %>
        </div>
        <div class="tl-track">
          <div class="tl-dot"></div>
          <div class="tl-line"></div>
        </div>
        <div class="tl-card">
          <div class="tl-card-head">
            <div class="act-title"><%= a.title %></div>
            <div class="act-actions">
              <button class="act-btn" onclick='openEditActivity(<%- JSON.stringify(a) %>)' title="編輯">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
              </button>
              <button class="act-btn del" onclick="deleteActivity(<%= a.id %>)" title="刪除">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="3 6 5 6 21 6"/>
                  <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                  <path d="M10 11v6M14 11v6"/>
                </svg>
              </button>
            </div>
          </div>
          <% if (a.location) { %>
            <div class="act-loc">
              <svg width="11" height="13" viewBox="0 0 24 28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
                <circle cx="12" cy="9" r="2.5"/>
              </svg>
              <%= a.location %>
            </div>
          <% } %>
          <% if (a.image_url) { %>
            <img src="<%= a.image_url %>" alt="<%= a.title %>" class="act-img" loading="lazy" onerror="this.style.display='none'">
          <% } else if (['attraction','food'].includes(a.category) && a.location) {
               const wikiQ = a.location.replace(/（[^）]*）/g,'').replace(/\([^\)]*\)/g,'').split('・')[0].split('→')[0].trim();
          %>
            <div class="act-wiki-img" data-wiki="<%= wikiQ %>"></div>
          <% } %>
          <% if (a.description) { %>
            <div class="act-desc"><%= a.description %></div>
          <% } %>
          <% if (a.mapcode) { %>
          <div class="mapcode-row">
            <span class="mapcode-lbl">MAPCODE</span>
            <span class="mapcode-val" id="mc-<%= a.id %>"><%= a.mapcode %></span>
            <button class="mapcode-copy" onclick="copyMC('<%= a.mapcode %>',this)" title="複製">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
              </svg>
            </button>
          </div>
          <% } %>
          <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
            <span class="cat-pill">
              <%= catMap[a.category] ? catMap[a.category].ico : '📌' %>
              <%= catMap[a.category] ? catMap[a.category].lbl : a.category %>
            </span>
            <% const mapLink = a.map_url || (a.location ? 'https://maps.google.com/?q=' + encodeURIComponent(a.location + '，日本') : ''); %>
            <% if (mapLink) { %>
              <a href="<%= mapLink %>" target="_blank" rel="noopener" class="act-map">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                導航
              </a>
            <% } %>
          </div>
          <% if (a.category === 'transport') { %>
          <%
            const actStr = a.title + ' ' + (a.location || '');
            const stationEntry = stationMapDB.find(e => e.keys.some(k => actStr.includes(k)));
            const stationMapUrl = stationEntry ? stationEntry.url : null;
            const gmTransit = a.lat && a.lng
              ? 'https://www.google.com/maps/dir/?api=1&destination=' + a.lat + ',' + a.lng + '&travelmode=transit'
              : 'https://www.google.com/maps/dir/?api=1&destination=' + encodeURIComponent((a.location||a.title)+'，日本') + '&travelmode=transit';
            const yahooQ = encodeURIComponent(a.location || a.title);
          %>
          <div class="transit-links">
            <a href="<%= gmTransit %>" target="_blank" rel="noopener" class="transit-btn transit-btn-map">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              乘車路線
            </a>
            <a href="https://transit.yahoo.co.jp/search/result?to=<%= yahooQ %>&timeType=departure&useJR=1&usePrivate=1&useSubway=1&useBus=1" target="_blank" rel="noopener" class="transit-btn transit-btn-time">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              時刻表
            </a>
            <a href="https://www.navitime.co.jp/transfer/searchlist?orvStationName=<%= yahooQ %>" target="_blank" rel="noopener" class="transit-btn transit-btn-nav">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
              NAVITIME
            </a>
            <% if (stationMapUrl) { %>
            <a href="<%= stationMapUrl %>" target="_blank" rel="noopener" class="transit-btn transit-btn-stmap">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              站內地圖
            </a>
            <% } %>
          </div>
          <% } %>
        </div>
      </div>
    <% }) %>
  <% } %>

  <button class="add-btn" onclick="openAddActivity(<%= day.id %>)">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
    新增行程
  </button>
</div>

<script>
(async () => {
  const els = [...document.querySelectorAll('.act-wiki-img')];
  if (!els.length) return;

  // 繁體中文 → 日文漢字對應（用於 ja.wikipedia.org 查詢）
  const TC2JP = [
    ['稻荷','稲荷'],['稻','稲'],['黑','黒'],['國','国'],['關','関'],
    ['兩','両'],['來','来'],['會','会'],['萬','万'],['鐵','鉄'],
    ['號','号'],['區','区'],['藝','芸'],['觀','観'],['覽','覧'],
    ['澤','沢'],['濱','浜'],['橋','橋'],['豐','豊'],['禪','禅'],
    ['龍','龍'],['總','総'],['體','体'],['寶','宝'],['齊','斉'],
    ['邊','辺'],['圓','円'],['驛','駅'],['處','処'],['廟','廟'],
  ];
  function toJP(s) {
    let r = s;
    for (const [tc, jp] of TC2JP) r = r.replaceAll(tc, jp);
    return r;
  }

  const rawTerms = [...new Set(els.map(e => e.dataset.wiki).filter(Boolean))];
  // 每個 term 同時用原始繁體與轉換後日文查詢
  const termMap = {}; // jpTerm → originalTerm
  rawTerms.forEach(t => { termMap[toJP(t)] = t; });
  const jpTerms = Object.keys(termMap);

  try {
    const r = await fetch(
      'https://ja.wikipedia.org/w/api.php?action=query&prop=pageimages&format=json&pithumbsize=800&origin=*&redirects=1&titles='
      + jpTerms.map(encodeURIComponent).join('|')
    );
    const d = await r.json();
    const imgMap = {}; // originalTerm → imgUrl
    for (const p of Object.values(d.query?.pages || {})) {
      if (!p.thumbnail?.source) continue;
      const orig = termMap[p.title] || p.title;
      imgMap[orig] = p.thumbnail.source;
    }
    for (const rd of (d.query?.redirects || [])) {
      const target = imgMap[termMap[rd.to] || rd.to];
      if (target) {
        const origFrom = termMap[rd.from] || rd.from;
        imgMap[origFrom] = target;
      }
    }
    els.forEach(el => {
      const term = el.dataset.wiki;
      const url = imgMap[term] || Object.entries(imgMap).find(([k]) =>
        k.includes(term.slice(0,3)) || term.includes(k.slice(0,3))
      )?.[1];
      if (url) {
        const img = document.createElement('img');
        img.src = url; img.className = 'act-img'; img.loading = 'lazy';
        img.onerror = () => img.remove();
        el.replaceWith(img);
      } else {
        el.remove();
      }
    });
  } catch { els.forEach(e => e.remove()); }
})();
</script>
<%- include('partials/footer', { activePage: 'home' }) %>
