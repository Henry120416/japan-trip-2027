        <line x1="5" y1="19" x2="5" y2="21"/>
        <line x1="19" y1="19" x2="19" y2="21"/>
      </svg>
    </div>
    <span class="shortcut-lbl">住宿資訊</span>
  </a>
  <a href="/flights" class="shortcut-item">
    <div class="shortcut-ico" style="background:#FEF4EE">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D48060" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 2L11 13"/>
        <path d="M22 2L15 22L11 13L2 9L22 2z"/>
      </svg>
    </div>
