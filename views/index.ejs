  </a>
  <a href="/restaurants" class="shortcut-item">
    <div class="shortcut-ico" style="background:#FEF8EB">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#CCA030" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <line x1="8" y1="3" x2="8" y2="22"/>
        <path d="M5 3v6a3 3 0 006 0V3"/>
        <line x1="16" y1="3" x2="16" y2="22"/>
      </svg>
    </div>
    <span class="shortcut-lbl">餐廳</span>
  </a>
  <a href="/" class="shortcut-item">
    <div class="shortcut-ico" style="background:#EEEFFE">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#7080CC" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="4" width="18" height="18" rx="2"/>
        <line x1="16" y1="2" x2="16" y2="6"/>
        <line x1="8" y1="2" x2="8" y2="6"/>
        <line x1="3" y1="10" x2="21" y2="10"/>
        <line x1="8" y1="14" x2="16" y2="14"/>
        <line x1="8" y1="18" x2="12" y2="18"/>
      </svg>
    </div>
    <span class="shortcut-lbl">Event</span>
  </a>
</div>

<!-- Day Cards — 2-column staggered grid -->
<div class="section" style="padding-top:22px;padding-bottom:32px">
  <div class="section-hd">
    <div class="section-label">六日行程</div>
    <span class="section-see-all">SEE ALL</span>
  </div>

  <%
    const DAY_GRADIENTS = [
      'linear-gradient(140deg,#5C6BC0,#7E57C2)',
      'linear-gradient(140deg,#26A69A,#00796B)',
      'linear-gradient(140deg,#29B6F6,#0277BD)',
      'linear-gradient(140deg,#FF7043,#BF360C)',
      'linear-gradient(140deg,#42A5F5,#1565C0)',
      'linear-gradient(140deg,#EC407A,#880E4F)',
    ];
    const DAY_ICONS = ['⛩','🦌','🌊','🏙','⚓','✈'];
    const weekMap = ['日','一','二','三','四','五','六'];
  %>

  <%
    // Split into left (even index) and right (odd index) columns
    // Left:  Day1(tall) Day3(short) Day5(tall)
    // Right: Day2(short) Day4(tall) Day6(short)
    const leftDays  = days.map((d,i) => ({...d, _i:i})).filter((_,j) => j%2===0);
    const rightDays = days.map((d,i) => ({...d, _i:i})).filter((_,j) => j%2===1);
    const leftH  = ['tall','short','tall'];
    const rightH = ['short','tall','short'];
  %>
  <div class="day-grid">
    <div class="day-col">
      <% leftDays.forEach((day, j) => { %>
        <a href="/day/<%= day.date %>" class="day-card day-card--<%= leftH[j]||'short' %>">
          <% if (day.heroImg) { %>
            <img class="dc-photo" src="<%= day.heroImg %>" alt="" loading="lazy">
            <div class="dc-overlay"></div>
          <% } else { %>
            <div class="dc-bg" style="background:<%= DAY_GRADIENTS[day._i] %>"></div>
          <% } %>
          <div class="dc-info">
            <div class="dc-info-city"><%= day.city %></div>
            <div class="dc-info-title"><%= day.title %></div>
            <% if (day.activity_count > 0) { %>
            <div class="dc-badge">
              <svg width="9" height="9" viewBox="0 0 24 24" fill="#F59E0B"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              Day <%= day._i+1 %> &nbsp;·&nbsp; <%= day.activity_count %> 個行程
            </div>
            <% } %>
          </div>
        </a>
      <% }) %>
    </div>
    <div class="day-col">
      <% rightDays.forEach((day, j) => { %>
        <a href="/day/<%= day.date %>" class="day-card day-card--<%= rightH[j]||'tall' %>">
          <% if (day.heroImg) { %>
            <img class="dc-photo" src="<%= day.heroImg %>" alt="" loading="lazy">
            <div class="dc-overlay"></div>
          <% } else { %>
            <div class="dc-bg" style="background:<%= DAY_GRADIENTS[day._i] %>"></div>
          <% } %>
          <div class="dc-info">
            <div class="dc-info-city"><%= day.city %></div>
            <div class="dc-info-title"><%= day.title %></div>
            <% if (day.activity_count > 0) { %>
            <div class="dc-badge">
              <svg width="9" height="9" viewBox="0 0 24 24" fill="#F59E0B"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              Day <%= day._i+1 %> &nbsp;·&nbsp; <%= day.activity_count %> 個行程
            </div>
            <% } %>
          </div>
        </a>
      <% }) %>
    </div>
  </div>
</div>

<%- include('partials/footer', { activePage: 'home' }) %>
