<%- include('partials/header', { pageTitle: '大阪京都之旅', navTitle: '行程總覽', navBack: null }) %>

<div class="hero">
  <div class="hero-label">2027 Spring</div>
  <div class="hero-title">大阪京都之旅</div>
  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:6px;margin-top:4px">
    <div class="hero-sub">04/17 — 04/22 &nbsp;·&nbsp; 6 人同行</div>
    <a href="/overview-map" class="map-route-link">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/>
        <line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/>
      </svg>
      動線總覽
    </a>
  </div>
</div>

<div class="section">
  <div class="section-label">六日行程</div>
  <% const weekMap = ['日','一','二','三','四','五','六']; %>
  <% days.forEach((day, i) => { %>
    <%
      const d = new Date(day.date + 'T00:00:00');
      const wd = weekMap[d.getDay()];
      const md = `${d.getMonth()+1}/${String(d.getDate()).padStart(2,'0')}`;
    %>
    <a href="/day/<%= day.date %>" class="day-card">
      <div class="day-num">
        <span class="day-num-n"><%= i+1 %></span>
        <span class="day-num-l">Day</span>
      </div>
      <div class="day-card-body">
        <div class="day-card-title">
          <%= day.title %>
          <span class="city-tag"><%= day.city %></span>
        </div>
        <div class="day-card-sub">
          週<%= wd %> &nbsp;<%= md %>
          <% if (day.activity_count > 0) { %>
            &nbsp;·&nbsp; <%= day.activity_count %> 個行程
          <% } else { %>
            &nbsp;·&nbsp; 尚無行程
          <% } %>
        </div>
      </div>
      <svg class="chevron" width="8" height="14" viewBox="0 0 8 14" fill="none">
        <path d="M1 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  <% }) %>
</div>

<%- include('partials/footer', { activePage: 'home' }) %>
