<%- include('partials/header', { pageTitle: '大阪京都之旅', navTitle: '', navBack: null, navClass: 'nav--home', pageClass: 'page--home' }) %>

<!-- Header — matches "Hi Antenio!" pattern -->
<div class="home-hero">
  <div class="home-hero-row">
    <div>
      <div class="home-hero-title">大阪京都之旅</div>
      <div class="home-hero-sub">
        行程至&nbsp;<span class="home-hero-accent">京都・大阪・神戶</span>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color:var(--t4)">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </div>
    </div>
    <a href="/info" class="home-hero-btn" title="旅遊資訊">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
    </a>
  </div>
</div>

<!-- Category Shortcuts -->
<div class="shortcut-row">
  <a href="/" class="shortcut-item">
    <div class="shortcut-ico" style="background:#EEF2FF">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="#6366F1">
        <path d="M17 3h1a3 3 0 013 3v13a3 3 0 01-3 3H6a3 3 0 01-3-3V6a3 3 0 013-3h1V1h2v2h6V1h2v2zM5 9v10a1 1 0 001 1h12a1 1 0 001-1V9H5zm2 3h2v2H7v-2zm4 0h2v2h-2v-2zm4 0h2v2h-2v-2z"/>
      </svg>
    </div>
    <span class="shortcut-lbl" style="color:#6366F1">行程</span>
  </a>
  <a href="/overview-map" class="shortcut-item">
    <div class="shortcut-ico" style="background:#ECFDF5">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="#10B981">
        <path d="M12 2a7 7 0 017 7c0 4.9-7 13-7 13S5 13.9 5 9a7 7 0 017-7zm0 4.5a2.5 2.5 0 100 5 2.5 2.5 0 000-5z"/>
      </svg>
    </div>
    <span class="shortcut-lbl" style="color:#10B981">動線</span>
  </a>
  <a href="/expenses" class="shortcut-item">
    <div class="shortcut-ico" style="background:#FFFBEB">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="#F59E0B">
        <path d="M2 8h20v10a2 2 0 01-2 2H4a2 2 0 01-2-2V8zm0-2V6a2 2 0 012-2h16a2 2 0 012 2H2zm4 9a1 1 0 102 0 1 1 0 00-2 0zm4 0a1 1 0 102 0 1 1 0 00-2 0z"/>
      </svg>
    </div>
    <span class="shortcut-lbl" style="color:#F59E0B">費用</span>
  </a>
  <a href="/info" class="shortcut-item">
    <div class="shortcut-ico" style="background:#FFF1F2">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="#F43F5E">
        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
      </svg>
    </div>
    <span class="shortcut-lbl" style="color:#F43F5E">資訊</span>
  </a>
</div>

<!-- Day Cards — 2-column staggered grid -->
<div class="section" style="padding-top:22px;padding-bottom:32px">
  <div class="section-hd">
    <div class="section-label">六日行程</div>
    <span class="section-see-all">SEE ALL</span>
  </div>

  <%
    const DAY_GRADIENTS = [
      'linear-gradient(140deg,#5C6BC0,#7E57C2)',
      'linear-gradient(140deg,#26A69A,#00796B)',
      'linear-gradient(140deg,#29B6F6,#0277BD)',
      'linear-gradient(140deg,#FF7043,#BF360C)',
      'linear-gradient(140deg,#42A5F5,#1565C0)',
      'linear-gradient(140deg,#EC407A,#880E4F)',
    ];
    const DAY_ICONS = ['⛩','🦌','🌊','🏙','⚓','✈'];
    const weekMap = ['日','一','二','三','四','五','六'];
  %>

  <%
    // Split into left (even index) and right (odd index) columns
    // Left:  Day1(tall) Day3(short) Day5(tall)
    // Right: Day2(short) Day4(tall) Day6(short)
    const leftDays  = days.map((d,i) => ({...d, _i:i})).filter((_,j) => j%2===0);
    const rightDays = days.map((d,i) => ({...d, _i:i})).filter((_,j) => j%2===1);
    const leftH  = ['tall','short','tall'];
    const rightH = ['short','tall','short'];
  %>
  <div class="day-grid">
    <div class="day-col">
      <% leftDays.forEach((day, j) => { %>
        <a href="/day/<%= day.date %>" class="day-card day-card--<%= leftH[j]||'short' %>">
          <% if (day.heroImg) { %>
            <img class="dc-photo" src="<%= day.heroImg %>" alt="" loading="lazy">
            <div class="dc-overlay"></div>
          <% } else { %>
            <div class="dc-bg" style="background:<%= DAY_GRADIENTS[day._i] %>"></div>
          <% } %>
          <div class="dc-info">
            <div class="dc-info-city"><%= day.city %></div>
            <div class="dc-info-title"><%= day.title %></div>
            <% if (day.activity_count > 0) { %>
            <div class="dc-badge">
              <svg width="9" height="9" viewBox="0 0 24 24" fill="#F59E0B"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              Day <%= day._i+1 %> &nbsp;·&nbsp; <%= day.activity_count %> 個行程
            </div>
            <% } %>
          </div>
        </a>
      <% }) %>
    </div>
    <div class="day-col">
      <% rightDays.forEach((day, j) => { %>
        <a href="/day/<%= day.date %>" class="day-card day-card--<%= rightH[j]||'tall' %>">
          <% if (day.heroImg) { %>
            <img class="dc-photo" src="<%= day.heroImg %>" alt="" loading="lazy">
            <div class="dc-overlay"></div>
          <% } else { %>
            <div class="dc-bg" style="background:<%= DAY_GRADIENTS[day._i] %>"></div>
          <% } %>
          <div class="dc-info">
            <div class="dc-info-city"><%= day.city %></div>
            <div class="dc-info-title"><%= day.title %></div>
            <% if (day.activity_count > 0) { %>
            <div class="dc-badge">
              <svg width="9" height="9" viewBox="0 0 24 24" fill="#F59E0B"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              Day <%= day._i+1 %> &nbsp;·&nbsp; <%= day.activity_count %> 個行程
            </div>
            <% } %>
          </div>
        </a>
      <% }) %>
    </div>
  </div>
</div>

<%- include('partials/footer', { activePage: 'home' }) %>
