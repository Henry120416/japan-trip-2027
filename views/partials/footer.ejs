  </div><!-- .page -->

  <!-- Tab Bar -->
  <nav class="tab-bar">
    <a href="/" class="tab <%= typeof activePage !== 'undefined' && activePage === 'home' ? 'active' : '' %>">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z"/>
        <path d="M9 21V12h6v9"/>
      </svg>
      <span class="tab-lbl">首頁</span>
    </a>
    <a href="/overview-map" class="tab <%= typeof activePage !== 'undefined' && activePage === 'map' ? 'active' : '' %>">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/>
        <line x1="9" y1="3" x2="9" y2="18"/>
        <line x1="15" y1="6" x2="15" y2="21"/>
      </svg>
      <span class="tab-lbl">動線</span>
    </a>
    <a href="/expenses" class="tab <%= typeof activePage !== 'undefined' && activePage === 'expenses' ? 'active' : '' %>">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="6" width="20" height="14" rx="3"/>
        <path d="M2 10h20"/>
        <circle cx="16" cy="15" r="1.5" fill="currentColor" stroke="none"/>
      </svg>
      <span class="tab-lbl">費用</span>
    </a>
    <a href="/luggage" class="tab <%= typeof activePage !== 'undefined' && activePage === 'luggage' ? 'active' : '' %>">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="7" width="20" height="14" rx="2"/>
        <path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2"/>
        <line x1="12" y1="11" x2="12" y2="17"/>
        <line x1="9" y1="14" x2="15" y2="14"/>
      </svg>
      <span class="tab-lbl">行李</span>
    </a>
  </nav>
</div><!-- .app -->

<!-- ── PIN Modal ───────────────────────────────── -->
<div id="pinOverlay" class="overlay" onclick="if(event.target===this)closePinModal()">
  <div class="sheet">
    <div class="sheet-handle"></div>
    <div class="sheet-title">輸入編輯密碼</div>
    <div class="fg">
      <input type="password" id="pinField" class="pin-field" placeholder="••••••••"
             autocomplete="off" onkeydown="if(event.key==='Enter')submitPin()">
    </div>
    <div class="btn-row">
      <button class="btn btn-sec" onclick="closePinModal()">取消</button>
      <button class="btn btn-pri" onclick="submitPin()">確認</button>
    </div>
  </div>
</div>

<!-- ── Activity Modal ────────────────────────────── -->
<div id="actOverlay" class="overlay" onclick="if(event.target===this)closeActModal()">
  <div class="sheet">
    <div class="sheet-handle"></div>
    <div class="sheet-title" id="actModalTitle">新增行程</div>
    <input type="hidden" id="actDayId">
    <input type="hidden" id="actId">
    <div class="fg">
      <label>類別</label>
      <div class="cat-grid" id="catGrid">
        <button type="button" class="cat-opt sel" data-cat="transport" onclick="selectCat(this)">
          <span class="ico">✈</span><span class="lbl">交通</span>
        </button>
        <button type="button" class="cat-opt" data-cat="food" onclick="selectCat(this)">
          <span class="ico">🍜</span><span class="lbl">餐廳</span>
        </button>
        <button type="button" class="cat-opt" data-cat="attraction" onclick="selectCat(this)">
          <span class="ico">🏛</span><span class="lbl">景點</span>
        </button>
        <button type="button" class="cat-opt" data-cat="hotel" onclick="selectCat(this)">
          <span class="ico">🏨</span><span class="lbl">住宿</span>
        </button>
        <button type="button" class="cat-opt" data-cat="other" onclick="selectCat(this)">
          <span class="ico">📌</span><span class="lbl">其他</span>
        </button>
      </div>
    </div>
    <div class="fg">
      <label>開始時間（出發 / 抵達）</label>
      <input type="time" id="actTime" placeholder="09:00">
    </div>
    <div class="fg">
      <label>名稱 *</label>
      <input type="text" id="actTitle" placeholder="行程名稱">
    </div>
    <div class="fg">
      <label>地點</label>
      <input type="text" id="actLocation" placeholder="地點名稱">
    </div>
    <div class="fg">
      <label>Google Maps 連結</label>
      <input type="url" id="actMapUrl" placeholder="https://maps.google.com/...">
    </div>
    <div class="fg">
      <label>景點圖片網址</label>
      <input type="url" id="actImageUrl" placeholder="https://... （選填）">
    </div>
    <div class="fg">
      <label>備注</label>
      <textarea id="actDesc" placeholder="補充說明..."></textarea>
    </div>
    <div class="fg">
      <label>MAPCODE（日本導航用）</label>
      <input type="text" id="actMapcode" placeholder="例：66 088 561*74">
    </div>
    <div class="btn-row">
      <button class="btn btn-sec" onclick="closeActModal()">取消</button>
      <button class="btn btn-pri" onclick="saveActivity()">儲存</button>
    </div>
  </div>
</div>

<!-- ── Expense Modal ─────────────────────────────── -->
<div id="expOverlay" class="overlay" onclick="if(event.target===this)closeExpModal()">
  <div class="sheet">
    <div class="sheet-handle"></div>
    <div class="sheet-title">新增費用</div>
    <input type="hidden" id="expDayId">
    <div class="fg">
      <label>名稱 *</label>
      <input type="text" id="expTitle" placeholder="費用項目">
    </div>
    <div class="fg">
      <label>日圓 (¥)</label>
      <input type="number" id="expJpy" placeholder="0" min="0">
    </div>
    <div class="fg">
      <label>台幣 (NT$)</label>
      <input type="number" id="expTwd" placeholder="0" min="0">
    </div>
    <div class="fg">
      <label>付款人</label>
      <input type="text" id="expPayer" placeholder="誰付的？">
    </div>
    <div class="fg">
      <label>備注</label>
      <textarea id="expNotes" placeholder="補充說明..." style="height:60px"></textarea>
    </div>
    <div class="btn-row">
      <button class="btn btn-sec" onclick="closeExpModal()">取消</button>
      <button class="btn btn-pri" onclick="saveExpense()">儲存</button>
    </div>
  </div>
</div>

<!-- Toast -->
<div id="toast" class="toast"></div>

<script src="/js/main.js"></script>
<% if (typeof extraScript !== 'undefined' && extraScript) { %>
<script src="<%= extraScript %>"></script>
<% } %>
</body>
</html>
