<%
function expCat(title) {
  if (/電車|JR|南海|阪神|阪急|交通|宅配|HARUKA|纜車|機場|搭乘|Rapi|電鐵|巴士/.test(title)) return '交通';
  if (/入場費|門票|參觀|入場|入館/.test(title)) return '景點門票';
  if (/午餐|晚餐|早餐|茶|燒肉|牛肉|料理|餐|市場|飲食|壽司|拉麵|串炸|甜點|美食|抹茶/.test(title)) return '餐飲';
  if (/購物|Outlet|免稅|手信|伴手禮/.test(title)) return '購物';
  if (/住宿|飯店|旅館|Hotel/.test(title)) return '住宿';
  return '其他';
}
const PERSONS = 6;
const catColors = { '交通':'#5E97F6','景點門票':'#FF9F43','餐飲':'#66BB6A','購物':'#EE5A24','住宿':'#A29BFE','其他':'#B2BEC3' };
const catTotals = {};
expenses.forEach(e => {
  const cat = expCat(e.title);
  catTotals[cat] = (catTotals[cat] || 0) + (e.amount_twd || 0);
});
const chartLabels = Object.keys(catTotals).filter(k => catTotals[k] > 0);
const chartData   = chartLabels.map(k => Math.ceil(catTotals[k] / PERSONS));
const chartColors = chartLabels.map(k => catColors[k]);

// Group by day
const grouped = {};
expenses.forEach(e => {
  const key = e.day_id || 'none';
  if (!grouped[key]) grouped[key] = {
    label: e.day_date ? e.day_title + ' · ' + e.day_date.replace(/-/g,'/') : '未分類',
    items: []
  };
  grouped[key].items.push(e);
});
%>
<%- include('partials/header', { pageTitle: '旅費紀錄', navTitle: '旅費紀錄', navBack: null }) %>

<style>
.plan-switch-wrap{padding:12px 16px 0}
.exp-chart-card{margin:0 16px 16px;background:var(--bg2);border-radius:16px;padding:20px 16px 16px;border:1px solid var(--border)}
.chart-wrap{position:relative;width:180px;height:180px;margin:0 auto 20px}
.chart-center{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;pointer-events:none}
.chart-center-val{font-size:1.25rem;font-weight:700;color:var(--t1);line-height:1.2}
.chart-center-lbl{font-size:.65rem;color:var(--t3);margin-top:2px}
.legend-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px 12px}
.legend-row{display:flex;align-items:center;gap:6px;font-size:.78rem}
.legend-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.legend-lbl{color:var(--t2);flex:1;min-width:0;white-space:nowrap}
.legend-val{color:var(--t1);font-weight:600;font-size:.78rem;white-space:nowrap}
.stats-strip{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;padding:0 16px 16px}
.stat-card{background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:12px 8px;text-align:center}
.stat-val{font-size:1rem;font-weight:700;color:var(--t1);line-height:1.2}
.stat-lbl{font-size:.68rem;color:var(--t3);margin-top:3px}
.exp-section-title{padding:4px 16px 6px;font-size:.72rem;font-weight:600;color:var(--t3);text-transform:uppercase;letter-spacing:.06em}
</style>

<!-- 方案切換 -->
<div class="plan-switch-wrap">
  <div class="plan-switch">
    <% plans.forEach(p => { %>
      <a href="/set-plan/<%= p.id %>?redirect=/expenses" class="plan-btn <%= currentPlan === p.id ? 'active' : '' %>">
        <span class="plan-btn-name"><%= p.name %></span>
        <span class="plan-btn-sub"><%= p.subtitle %></span>
      </a>
    <% }) %>
  </div>
</div>

<!-- Stats -->
<div class="stats-strip" style="margin-top:14px">
  <div class="stat-card">
    <div class="stat-val" style="font-size:.9rem">¥<%= total_jpy.toLocaleString() %></div>
    <div class="stat-lbl">總日圓</div>
  </div>
  <div class="stat-card">
    <div class="stat-val" style="font-size:.9rem">NT$<%= total_twd.toLocaleString() %></div>
    <div class="stat-lbl">總台幣</div>
  </div>
  <div class="stat-card">
    <div class="stat-val">NT$<%= per_person.toLocaleString() %></div>
    <div class="stat-lbl">每人均攤</div>
  </div>
</div>

<% if (chartLabels.length > 0) { %>
<!-- 圓餅圖 -->
<div class="exp-chart-card">
  <div class="section-label" style="margin-bottom:14px">單人預估花費分析</div>
  <div class="chart-wrap">
    <canvas id="expChart"></canvas>
    <div class="chart-center">
      <div class="chart-center-val">NT$<%= per_person.toLocaleString() %></div>
      <div class="chart-center-lbl">每人均攤</div>
    </div>
  </div>
  <div class="legend-grid">
    <% chartLabels.forEach((lbl, i) => { %>
      <div class="legend-row">
        <span class="legend-dot" style="background:<%= chartColors[i] %>"></span>
        <span class="legend-lbl"><%= lbl %></span>
        <span class="legend-val">NT$<%= chartData[i].toLocaleString() %></span>
      </div>
    <% }) %>
  </div>
</div>
<% } %>

<!-- 明細 -->
<div class="section">
  <% if (expenses.length === 0) { %>
    <div class="empty" style="padding:48px 24px">
      <div class="empty-icon">💴</div>
      <div class="empty-txt">尚無費用紀錄</div>
      <div class="empty-hint">點擊下方按鈕新增</div>
    </div>
  <% } else { %>
    <% Object.values(grouped).forEach(group => { %>
      <div class="exp-section-title"><%= group.label %></div>
      <div class="card-list" style="margin-bottom:12px">
        <% group.items.forEach(e => { %>
          <div class="exp-item">
            <div class="exp-info">
              <div class="exp-name"><%= e.title %></div>
              <% if (e.payer) { %><div class="exp-meta">付款：<%= e.payer %></div><% } %>
              <% if (e.notes) { %><div class="exp-meta"><%= e.notes %></div><% } %>
            </div>
            <div class="exp-amt">
              <% if (e.amount_jpy > 0) { %><div class="exp-jpy">¥<%= e.amount_jpy.toLocaleString() %></div><% } %>
              <% if (e.amount_twd > 0) { %><div class="exp-twd">NT$<%= e.amount_twd.toLocaleString() %></div><% } %>
            </div>
            <button class="exp-del" onclick="deleteExpense(<%= e.id %>)" title="刪除">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="3 6 5 6 21 6"/>
                <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                <path d="M10 11v6M14 11v6"/>
              </svg>
            </button>
          </div>
        <% }) %>
      </div>
    <% }) %>
  <% } %>

  <button class="add-btn" onclick="openAddExpense()">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
    新增費用
  </button>

  <script>
    const TRIP_DAYS = <%- JSON.stringify(days.map(d => ({ id: d.id, label: d.title + ' · ' + d.date.replace(/-/g,'/') }))) %>;
  </script>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function() {
  const canvas = document.getElementById('expChart');
  if (!canvas) return;
  new Chart(canvas, {
    type: 'doughnut',
    data: {
      labels: <%- JSON.stringify(chartLabels) %>,
      datasets: [{
        data: <%- JSON.stringify(chartData) %>,
        backgroundColor: <%- JSON.stringify(chartColors) %>,
        borderWidth: 2,
        borderColor: '#fff',
        hoverOffset: 6,
      }]
    },
    options: {
      cutout: '68%',
      plugins: { legend: { display: false }, tooltip: {
        callbacks: {
          label: ctx => ' NT$' + ctx.parsed.toLocaleString() + ' / 人'
        }
      }},
      animation: { duration: 600 },
    }
  });
})();
</script>

<%- include('partials/footer', { activePage: 'expenses' }) %>
